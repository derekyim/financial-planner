{
  "version": 2,
  "builds": [
    {
      "src": "ui/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "calc-engine/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "calc-engine/src/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/calc/(.*)",
      "dest": "/calc-engine/api/index.ts?path=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/ui/$1"
    }
  ]
}
